{
  "name": "claude-usage-analytics",
  "version": "0.4.0",
  "description": "Local-first token usage & imputed cost analytics for Claude Code. Offline parser + SQLite + live dashboard and static reports, with session-kind/SDLC classification, secret redaction, and per-project attribution. Self-bootstrapping Python; near-zero LLM overhead.",
  "author": {
    "name": "Krishnesh Pujari"
  },
  "repository": "https://github.com/krishnesh7/claude-usage-analytics",
  "license": "MIT",
  "keywords": ["usage", "cost", "analytics", "tokens", "dashboard", "productivity"],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop.sh"
      }
    ]
  },
  "commands": [
    "commands/usage.md",
    "commands/usage-report.md",
    "commands/usage-doc.md",
    "commands/stage.md",
    "commands/usage-parse.md",
    "commands/project-init.md",
    "commands/project-list.md",
    "commands/project-confirm.md",
    "commands/usage-guide.md",
    "commands/usage-compare.md"
  ],
  "skills": [
    "skills/getting-started",
    "skills/vs-session-report"
  ]
}
